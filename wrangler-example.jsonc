// wrangler-example.jsonc — 참고용 예시입니다. 이 파일 자체는 배포에 쓰이지 않습니다.
//
// GitHub 저장소에 이미 있는 wrangler.jsonc(Cloudflare가 자동 생성)를 열어
// 아래 두 항목이 있는지 확인하고, 없으면 추가하세요.
//   1. "main": "worker.js"                ← 워커 스크립트 지정 (AI 요약 API)
//   2. assets 안에 "binding": "ASSETS"    ← 워커가 정적 파일을 넘겨줄 통로
//
// 완성 예시 (name 값은 기존 파일의 것을 그대로 유지하세요):
{
  "name": "mse",
  "compatibility_date": "2026-07-01",
  "main": "worker.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  }
}
